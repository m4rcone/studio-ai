# GitHub API — used by Studio AI to read/write content files
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=your-github-org-or-user
GITHUB_REPO=your-repo-name
GITHUB_DEFAULT_BRANCH=main

# Anthropic — used by Studio AI agent
ANTHROPIC_API_KEY=your-anthropic-api-key

# Studio authentication
AUTH_SECRET=your-random-jwt-secret-at-least-32-chars
STUDIO_USERS=admin:team,client:client
STUDIO_PASSWORD=change-this-to-a-strong-password
